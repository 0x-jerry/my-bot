// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "bun"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  agentProfile String

  // Session title
  title    String  @default("")
  // Created by cron job
  cronTask Boolean @default(false)

  metadata String?
}

model Message {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  sessionId String
  role      String
  content   String?
  raw       String
  metadata  String?
}

model Memory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  content   String
  metadata  String?
}

model SessionCronJob {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  sessionId String

  cron   String
  reason String
}

model SessionTodo {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  content   String
  status    String   @default("pending")
}
