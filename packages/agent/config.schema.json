{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "Config.AgentConfig": {
            "properties": {
                "context": {
                    "$ref": "#/definitions/Config.AgentContextConfig",
                    "description": "Add extra context to the message."
                },
                "description": {
                    "type": "string"
                },
                "instruction": {
                    "type": "string"
                },
                "model": {
                    "description": "syntax: providerKey/modelName\n\neg: openai/gpt-3.5-turbo",
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "toolset": {
                    "items": {
                        "$ref": "#/definitions/ToolSet.All"
                    },
                    "type": "array"
                }
            },
            "type": "object"
        },
        "Config.AgentConfigs": {
            "additionalProperties": {
                "$ref": "#/definitions/Config.AgentConfig"
            },
            "type": "object"
        },
        "Config.AgentContextConfig": {
            "properties": {
                "extraPrompts": {
                    "description": "Load extra prompts from files.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "maxIterations": {
                    "default": 100,
                    "description": "Max number of tool call iterations.",
                    "type": "number"
                }
            },
            "type": "object"
        },
        "Config.McpConfigs": {
            "additionalProperties": {
                "$ref": "#/definitions/ToolSet.McpConfig"
            },
            "type": "object"
        },
        "Config.ProviderConfig": {
            "properties": {
                "apiKey": {
                    "type": "string"
                },
                "baseUrl": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "type": {
                    "const": "openai-compatible",
                    "description": "Only support openai compatible providers.",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "Config.ProviderConfigs": {
            "additionalProperties": {
                "$ref": "#/definitions/Config.ProviderConfig"
            },
            "type": "object"
        },
        "ToolSet.All": {
            "anyOf": [
                {
                    "$ref": "#/definitions/ToolSet.Mcp"
                },
                {
                    "$ref": "#/definitions/ToolSet.Skill"
                },
                {
                    "$ref": "#/definitions/ToolSet.Memory"
                },
                {
                    "$ref": "#/definitions/ToolSet.Shell"
                },
                {
                    "$ref": "#/definitions/ToolSet.Cron"
                },
                {
                    "$ref": "#/definitions/ToolSet.Env"
                },
                {
                    "$ref": "#/definitions/ToolSet.Todo"
                },
                {
                    "$ref": "#/definitions/ToolSet.FileSystem"
                }
            ]
        },
        "ToolSet.Cron": {
            "properties": {
                "type": {
                    "const": "cron",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "ToolSet.Env": {
            "properties": {
                "type": {
                    "const": "env",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "ToolSet.EnvConfig": {
            "additionalProperties": {
                "type": "string"
            },
            "type": "object"
        },
        "ToolSet.FileSystem": {
            "properties": {
                "type": {
                    "const": "filesystem",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "ToolSet.Mcp": {
            "properties": {
                "args": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "command": {
                    "type": "string"
                },
                "env": {
                    "$ref": "#/definitions/ToolSet.EnvConfig"
                },
                "envFile": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "filterTools": {
                    "description": "Filter tools by tool name.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "name": {
                    "description": "Root level mcp key",
                    "type": "string"
                },
                "remoteType": {
                    "enum": [
                        "http",
                        "sse"
                    ],
                    "type": "string"
                },
                "remoteUrl": {
                    "type": "string"
                },
                "type": {
                    "const": "mcp",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "ToolSet.McpConfig": {
            "properties": {
                "args": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "command": {
                    "type": "string"
                },
                "env": {
                    "$ref": "#/definitions/ToolSet.EnvConfig"
                },
                "envFile": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "filterTools": {
                    "description": "Filter tools by tool name.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "remoteType": {
                    "enum": [
                        "http",
                        "sse"
                    ],
                    "type": "string"
                },
                "remoteUrl": {
                    "type": "string"
                }
            },
            "type": "object"
        },
        "ToolSet.Memory": {
            "properties": {
                "remoteUrl": {
                    "description": "The URL of the memory server.",
                    "type": "string"
                },
                "type": {
                    "const": "memory",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "ToolSet.Shell": {
            "properties": {
                "rtkRewrite": {
                    "description": "This require rtk(https://github.com/rtk-ai/rtk) installed first, default is auto\n\n- \"auto\": rewrite if rtk installed\n- \"off\": disable the rewrite",
                    "enum": [
                        "auto",
                        "off"
                    ],
                    "type": "string"
                },
                "type": {
                    "const": "shell",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "ToolSet.Skill": {
            "properties": {
                "type": {
                    "const": "skill",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "ToolSet.Todo": {
            "properties": {
                "type": {
                    "const": "todo",
                    "type": "string"
                }
            },
            "type": "object"
        }
    },
    "properties": {
        "agents": {
            "$ref": "#/definitions/Config.AgentConfigs",
            "description": "AgentKey => AgentConfig"
        },
        "loggingLevel": {
            "description": "Enable logging.",
            "enum": [
                "debug",
                "error",
                "info",
                "warn"
            ],
            "type": "string"
        },
        "mcps": {
            "$ref": "#/definitions/Config.McpConfigs"
        },
        "provider": {
            "$ref": "#/definitions/Config.ProviderConfigs",
            "description": "ProviderKey => ProviderConfig"
        }
    },
    "type": "object"
}

