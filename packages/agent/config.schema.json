{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "Config.AgentConfig": {
            "properties": {
                "context": {
                    "$ref": "#/definitions/Config.AgentContextConfig",
                    "description": "Add extra context to the message."
                },
                "instruction": {
                    "type": "string"
                },
                "model": {
                    "description": "syntax: providerKey/modelName\neg: openai/gpt-3.5-turbo",
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "toolset": {
                    "items": {
                        "$ref": "#/definitions/ToolSet.All"
                    },
                    "type": "array"
                }
            },
            "type": "object"
        },
        "Config.AgentConfigs": {
            "additionalProperties": {
                "$ref": "#/definitions/Config.AgentConfig"
            },
            "type": "object"
        },
        "Config.AgentContextConfig": {
            "properties": {
                "addDate": {
                    "description": "Add current date to the message.",
                    "type": "boolean"
                },
                "extraPrompts": {
                    "description": "Load extra prompts from files.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "maxHistoryMessages": {
                    "description": "Max number of messages to keep in history.",
                    "type": "number"
                },
                "maxIterations": {
                    "description": "Max number of tool call iterations.",
                    "type": "number"
                }
            },
            "type": "object"
        },
        "Config.ProviderConfig": {
            "properties": {
                "apiKey": {
                    "type": "string"
                },
                "baseUrl": {
                    "type": "string"
                },
                "type": {
                    "const": "openai",
                    "description": "Only support openai compatible providers.",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "Config.ProviderConfigs": {
            "additionalProperties": {
                "$ref": "#/definitions/Config.ProviderConfig"
            },
            "type": "object"
        },
        "Record<string,string>": {
            "type": "object"
        },
        "ToolSet.All": {
            "anyOf": [
                {
                    "$ref": "#/definitions/ToolSet.McpTool"
                },
                {
                    "$ref": "#/definitions/ToolSet.SkillTool"
                }
            ]
        },
        "ToolSet.McpTool": {
            "properties": {
                "args": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "command": {
                    "type": "string"
                },
                "env": {
                    "$ref": "#/definitions/Record%3Cstring%2Cstring%3E"
                },
                "envFile": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "remote": {
                    "properties": {
                        "type": {
                            "enum": [
                                "http",
                                "sse"
                            ],
                            "type": "string"
                        },
                        "url": {
                            "description": "The URL of the MCP server.",
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "type": {
                    "const": "mcp",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "ToolSet.SkillTool": {
            "properties": {
                "type": {
                    "const": "skill",
                    "type": "string"
                }
            },
            "type": "object"
        }
    },
    "properties": {
        "agents": {
            "$ref": "#/definitions/Config.AgentConfigs",
            "description": "AgentKey => AgentConfig"
        },
        "loggingLevel": {
            "description": "Enable logging.",
            "enum": [
                "debug",
                "error",
                "info",
                "warn"
            ],
            "type": "string"
        },
        "provider": {
            "$ref": "#/definitions/Config.ProviderConfigs",
            "description": "ProviderKey => ProviderConfig"
        }
    },
    "type": "object"
}

